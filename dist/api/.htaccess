# Bloqueia acesso HTTP direto aos arquivos de configuração/segredos.
# (config.php apenas faz `return [...]`, então nem imprime nada — defesa extra.)
<FilesMatch "^config(\.example)?\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
