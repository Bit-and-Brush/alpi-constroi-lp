    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Alpi Constroi — Serviços de construção civil e remodelação de qualidade em Angola"
    />
    <meta property="og:title" content="Alpi Constroi" />
    <meta
      property="og:description"
      content="Serviços de construção civil e remodelação de qualidade em Angola"
    />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-primary" />
    <title>Alpi Constroi — Construção e Remodelação</title>
  </head>
  <body class="font-sans">
    <Header />
    <slot />
    <Footer />
  </body>
