---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Lang } from "../i18n/ui";

const currentLang = (Astro.currentLocale ?? "pt") as Lang;
---

<div class="flex items-center gap-1 text-sm font-semibold uppercase">
  <a
    href={getRelativeLocaleUrl("pt", "/")}
    class:list={[
      "transition-colors",
      currentLang === "pt"
        ? "text-primary"
        : "text-gray-500 hover:text-foreground",
    ]}
    aria-current={currentLang === "pt" ? "page" : undefined}
  >
    PT
  </a>
  <span class="text-gray-300">|</span>
  <a
    href={getRelativeLocaleUrl("en", "/")}
    class:list={[
      "transition-colors",
      currentLang === "en"
        ? "text-primary"
        : "text-gray-500 hover:text-foreground",
    ]}
    aria-current={currentLang === "en" ? "page" : undefined}
  >
    EN
  </a>
</div>
