---
import { Image } from "astro:assets";
import { services } from "@/data/services";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const lang = (Astro.currentLocale ?? "pt") as Lang;
const t = useTranslations(lang);
const localServices = services[lang];
---

<section class="w-full bg-primary/5 py-16 md:py-24" id="servicos">
  <div class="container mx-auto px-6">
    <!-- Header -->
    <div class="flex flex-col gap-6 mb-12">
      <span
        class="bg-foreground text-white text-sm px-4 py-1 rounded-full w-fit scroll-fade-up"
      >
        {t("services.tag")}
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-foreground scroll-fade-up">
        {t("services.title")}
      </h2>
      <p
        class="text-base md:text-lg text-foreground/70 max-w-2xl scroll-fade-up"
      >
        {t("services.description")}
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-6">
      {
        localServices.map((service) => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm scroll-fade-up">
            <div class="aspect-4/3 w-full bg-gray-200">
              {service.image && (
                <Image
                  src={service.image}
                  alt={service.title}
                  class="object-cover w-full h-full"
                />
              )}
            </div>
            <div class="p-6 flex flex-col gap-3">
              <h3 class="text-xl font-bold text-foreground">{service.title}</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">
                {service.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
