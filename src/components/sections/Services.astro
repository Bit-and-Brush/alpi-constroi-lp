---
import { services } from '../../data/services';
---

<section class="py-16 md:py-24 bg-gray-50" id="servicos">
  <div class="mx-auto max-w-7xl px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center mb-12">
      Os Nossos Serviços
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <div class="bg-white p-8 rounded-lg shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <span class="text-xl">🏗️</span>
          </div>
          <h3 class="text-xl font-semibold text-primary mb-3">
            {service.title}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
