---
import { Image } from "astro:assets";
// TODO: Replace with client's actual work photos
import work1 from "@/assets/img/projects/project-1.webp";
import work2 from "@/assets/img/projects/project-2.webp";
import work3 from "@/assets/img/projects/project-3.webp";
import { differentiators } from "@/data/differentiators";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const lang = (Astro.currentLocale ?? "pt") as Lang;
const t = useTranslations(lang);
const localDifferentiators = differentiators[lang];
---

<section class="w-full bg-white py-16 md:py-24" id="diferenciais">
  <div class="container mx-auto px-6">
    <!-- Header -->
    <div class="flex flex-col gap-6 mb-12">
      <span
        class="bg-foreground text-white text-sm px-4 py-1 rounded-full w-fit scroll-fade-up"
      >
        {t("differentiators.tag")}
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-foreground scroll-fade-up">
        {t("differentiators.title")}
      </h2>
    </div>

    <!-- Content grid with top-border separators -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16">
      {
        localDifferentiators.map((item) => (
          <p class="text-base md:text-lg text-foreground/80 leading-relaxed border-t border-gray-200 py-6 scroll-fade-up">
            {item.description}
          </p>
        ))
      }
    </div>

    <!-- Work photos -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
      {
        [work1, work2, work3].map((src) => (
          <div class="aspect-4/3 w-full bg-gray-200 rounded-2xl overflow-hidden scroll-fade-up">
            <Image src={src} alt="" class="object-cover w-full h-full" />
          </div>
        ))
      }
    </div>
  </div>
</section>
