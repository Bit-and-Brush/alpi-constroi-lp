---
import gallery1 from "@/assets/img/gallery-1.webp";
import gallery2 from "@/assets/img/gallery-2.webp";
import gallery3 from "@/assets/img/gallery-3.webp";
import gallery4 from "@/assets/img/gallery-4.webp";
import gallery5 from "@/assets/img/gallery-5.webp";
import gallery6 from "@/assets/img/gallery-6.webp";
import { differentiators } from "@/data/differentiators";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import { Image } from "astro:assets";

const lang = (Astro.currentLocale ?? "pt") as Lang;
const t = useTranslations(lang);
const localDifferentiators = differentiators[lang];
---

<section class="w-full bg-white py-16 md:py-24" id="diferenciais">
  <div class="container mx-auto px-6">
    <!-- Header -->
    <div class="flex flex-col gap-6 mb-12">
      <span
        class="bg-foreground text-white text-sm px-4 py-1 rounded-full w-fit scroll-fade-up"
      >
        {t("differentiators.tag")}
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-foreground scroll-fade-up">
        {t("differentiators.title")}
      </h2>
    </div>

    <!-- Content grid with top-border separators -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16">
      {
        localDifferentiators.map((item) => (
          <p class="text-base md:text-lg text-foreground/80 leading-relaxed border-t border-gray-200 py-6 scroll-fade-up">
            {item.description}
          </p>
        ))
      }
    </div>

    <!-- Gallery photos -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
      {
        [gallery1, gallery2, gallery3, gallery4, gallery5, gallery6].map(
          (src, i) => (
            <div
              class="relative aspect-4/3 w-full bg-gray-200 rounded-2xl overflow-hidden scroll-fade-up group cursor-pointer"
              style={`animation-delay: ${(i % 3) * 120}ms`}
            >
              <Image
                src={src}
                alt=""
                class="object-cover w-full h-full transition-transform duration-500 ease-out group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-foreground/0 group-hover:bg-foreground/20 transition-colors duration-500" />
            </div>
          ),
        )
      }
    </div>
  </div>
</section>
