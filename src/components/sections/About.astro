---
import { Image } from "astro:assets";
import AboutUsImage from "@/assets/img/about-us.webp";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const lang = (Astro.currentLocale ?? "pt") as Lang;
const t = useTranslations(lang);
---

<section class="w-full bg-white py-16 md:py-24" id="sobre">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 items-start gap-12">
      <!-- Left column -->
      <div class="flex flex-col gap-6">
        <span
          class="bg-foreground text-white text-sm px-4 py-1 rounded-full w-fit scroll-fade-up"
        >
          {t("about.tag")}
        </span>

        <h2
          class="text-3xl md:text-5xl font-bold text-foreground leading-tight scroll-fade-up"
        >
          {t("about.title")}
        </h2>

        <p class="text-base md:text-lg leading-relaxed scroll-fade-up">
          {t("about.p1")}
        </p>

        <p
          class="text-base md:text-lg text-foreground/80 leading-relaxed scroll-fade-up"
        >
          {t("about.p2")}
        </p>

        <p
          class="text-base md:text-lg text-foreground/80 leading-relaxed scroll-fade-up"
        >
          {t("about.p3")}
        </p>
      </div>

      <!-- Right column -->
      <div class="flex flex-col gap-8 scroll-fade-left">
        <div
          class="aspect-4/3 w-full bg-gray-200 rounded-2xl shadow-xl overflow-clip"
        >
          <Image src={AboutUsImage} alt={t("about.alt")} />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="bg-primary/10 rounded-xl p-6">
            <p class="text-3xl font-bold text-foreground">17+</p>
            <p class="text-sm text-foreground/70 mt-1">{t("about.stat.years")}</p>
          </div>
          <div class="bg-primary/10 rounded-xl p-6">
            <p class="text-3xl font-bold text-foreground">500+</p>
            <p class="text-sm text-foreground/70 mt-1">{t("about.stat.clients")}</p>
          </div>
          <div class="bg-primary/10 rounded-xl p-6">
            <p class="text-3xl font-bold text-foreground">600+</p>
            <p class="text-sm text-foreground/70 mt-1">{t("about.stat.works")}</p>
          </div>
          <div class="bg-primary/10 rounded-xl p-6">
            <p class="text-3xl font-bold text-foreground">24/7</p>
            <p class="text-sm text-foreground/70 mt-1">{t("about.stat.support")}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
