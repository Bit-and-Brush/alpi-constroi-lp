---
import { projects } from '../../data/projects';
---

<section class="py-16 md:py-24 bg-gray-50" id="projetos">
  <div class="mx-auto max-w-7xl px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center mb-12">
      Nossos Projetos
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="group relative overflow-hidden rounded-lg h-64 bg-gradient-to-br from-gray-300 to-gray-400 cursor-pointer">
          <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-50 transition-opacity duration-300 z-10"></div>

          <div class="absolute inset-0 flex flex-col justify-end p-6 z-20">
            <div class="text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <p class="text-sm font-medium text-accent">{project.category}</p>
              <h3 class="text-xl font-bold">{project.title}</h3>
              <p class="text-sm text-gray-300 mt-1">{project.year}</p>
            </div>
          </div>

          <div class="absolute inset-0 bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
            <span class="text-gray-500 text-center">
              <p class="font-semibold">Imagem do Projeto</p>
              <p class="text-sm mt-1">{project.title}</p>
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
