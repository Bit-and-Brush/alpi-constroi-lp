---
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const lang = (Astro.currentLocale ?? "pt") as Lang;
const t = useTranslations(lang);
---

<section class="w-full bg-white py-16 md:py-24" id="contacto">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

      <!-- Left: info -->
      <div class="flex flex-col gap-6">
        <span class="bg-foreground text-white text-sm px-4 py-1 rounded-full w-fit scroll-fade-up">
          {t("contact.tag")}
        </span>
        <h2 class="text-3xl md:text-5xl font-bold text-foreground scroll-fade-up">
          {t("contact.title")}
        </h2>
        <p class="text-base md:text-lg text-foreground/80 leading-relaxed scroll-fade-up">
          {t("contact.description")}
        </p>
        <div class="flex flex-col gap-2 mt-4 scroll-fade-up">
          <p class="text-foreground/80">
            <span class="font-bold text-foreground">{t("contact.email.label")}</span> geral@alpiconstroi.com
          </p>
          <p class="text-foreground/80">
            <span class="font-bold text-foreground">{t("contact.phone.label")}</span> 222 732 222
          </p>
          <p class="text-foreground/80">
            <span class="font-bold text-foreground">{t("contact.address.label")}</span> {t("contact.address.value")}
          </p>
          <p class="text-foreground/80">
            <span class="font-bold text-foreground">{t("contact.hours.label")}</span> {t("contact.hours.value")}
          </p>
        </div>
      </div>

      <!-- Right: form -->
      <form
        id="contact-form"
        class="flex flex-col gap-6"
        novalidate
        data-err-name-required={t("contact.error.name.required")}
        data-err-name-min={t("contact.error.name.minLength")}
        data-err-email-required={t("contact.error.email.required")}
        data-err-email-invalid={t("contact.error.email.invalid")}
        data-err-phone-required={t("contact.error.phone.required")}
        data-err-phone-invalid={t("contact.error.phone.invalid")}
        data-err-message-required={t("contact.error.message.required")}
        data-err-message-min={t("contact.error.message.minLength")}
        data-msg-success={t("contact.success")}
        data-msg-error={t("contact.error.generic")}
        data-label-submit={t("contact.form.submit")}
        data-label-submitting={t("contact.form.submitting")}
      >
        <div class="flex flex-col gap-1">
          <label for="nome" class="text-sm font-bold text-foreground">{t("contact.form.name.label")}</label>
          <input
            type="text"
            id="nome"
            name="nome"
            placeholder={t("contact.form.name.placeholder")}
            class="border border-gray-300 rounded-lg px-4 py-3 w-full text-foreground placeholder:text-foreground/40 focus:outline-none focus:border-primary transition-colors"
          />
          <span id="nome-error" class="text-red-500 text-xs hidden"></span>
        </div>

        <div class="flex flex-col gap-1">
          <label for="email" class="text-sm font-bold text-foreground">{t("contact.form.email.label")}</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="me@mail.com"
            class="border border-gray-300 rounded-lg px-4 py-3 w-full text-foreground placeholder:text-foreground/40 focus:outline-none focus:border-primary transition-colors"
          />
          <span id="email-error" class="text-red-500 text-xs hidden"></span>
        </div>

        <div class="flex flex-col gap-1">
          <label for="telefone" class="text-sm font-bold text-foreground">{t("contact.form.phone.label")}</label>
          <input
            type="tel"
            id="telefone"
            name="telefone"
            placeholder={t("contact.form.phone.placeholder")}
            maxlength="9"
            class="border border-gray-300 rounded-lg px-4 py-3 w-full text-foreground placeholder:text-foreground/40 focus:outline-none focus:border-primary transition-colors"
          />
          <span id="telefone-error" class="text-red-500 text-xs hidden"></span>
        </div>

        <div class="flex flex-col gap-1">
          <label for="mensagem" class="text-sm font-bold text-foreground">{t("contact.form.message.label")}</label>
          <textarea
            id="mensagem"
            name="mensagem"
            rows="4"
            maxlength="300"
            placeholder={t("contact.form.message.placeholder")}
            class="border border-gray-300 rounded-lg px-4 py-3 w-full text-foreground placeholder:text-foreground/40 focus:outline-none focus:border-primary transition-colors resize-none"
          ></textarea>
          <div class="flex justify-between items-center">
            <span id="mensagem-error" class="text-red-500 text-xs hidden"></span>
            <span id="mensagem-count" class="text-xs text-foreground/40 ml-auto">0/300</span>
          </div>
        </div>

        <span id="form-feedback" class="text-sm hidden"></span>

        <button
          type="submit"
          class="bg-primary text-white font-semibold px-8 py-3 rounded-full uppercase tracking-widest hover:opacity-85 active:scale-95 transition-all self-end flex items-center gap-2"
        >
          <svg id="submit-spinner" class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span id="submit-label">{t("contact.form.submit")}</span>
        </button>
      </form>

    </div>
  </div>
</section>

<script>
  import { submitContactForm } from "../../scripts/contact-form";

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const feedback = document.getElementById("form-feedback") as HTMLElement;
  const d = form.dataset;

  function sanitize(value: string): string {
    return value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#x27;");
  }

  const mensagemEl = document.getElementById("mensagem") as HTMLTextAreaElement;
  const mensagemCount = document.getElementById("mensagem-count") as HTMLElement;
  mensagemEl.addEventListener("input", () => {
    mensagemCount.textContent = `${mensagemEl.value.length}/300`;
  });

  function showError(id: string, msg: string) {
    const el = document.getElementById(id) as HTMLElement;
    el.textContent = msg;
    el.classList.remove("hidden");
  }

  function clearError(id: string) {
    const el = document.getElementById(id) as HTMLElement;
    el.textContent = "";
    el.classList.add("hidden");
  }

  ["nome", "email", "telefone", "mensagem"].forEach((field) => {
    document.getElementById(field)?.addEventListener("input", () =>
      clearError(`${field}-error`)
    );
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    let valid = true;

    const nome = (document.getElementById("nome") as HTMLInputElement).value.trim();
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const telefone = (document.getElementById("telefone") as HTMLInputElement).value.trim();
    const mensagem = (document.getElementById("mensagem") as HTMLTextAreaElement).value.trim();

    if (!nome) {
      showError("nome-error", d.errNameRequired!);
      valid = false;
    } else if (nome.length < 2) {
      showError("nome-error", d.errNameMin!);
      valid = false;
    } else {
      clearError("nome-error");
    }

    if (!email) {
      showError("email-error", d.errEmailRequired!);
      valid = false;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError("email-error", d.errEmailInvalid!);
      valid = false;
    } else {
      clearError("email-error");
    }

    if (!telefone) {
      showError("telefone-error", d.errPhoneRequired!);
      valid = false;
    } else if (!/^(\+244\s?)?[29]\d{2}\s?\d{3}\s?\d{3}$/.test(telefone)) {
      showError("telefone-error", d.errPhoneInvalid!);
      valid = false;
    } else {
      clearError("telefone-error");
    }

    if (!mensagem) {
      showError("mensagem-error", d.errMessageRequired!);
      valid = false;
    } else if (mensagem.length < 10) {
      showError("mensagem-error", d.errMessageMin!);
      valid = false;
    } else {
      clearError("mensagem-error");
    }

    if (!valid) return;

    const btn = form.querySelector("button[type='submit']") as HTMLButtonElement;
    const spinner = document.getElementById("submit-spinner") as HTMLElement;
    const label = document.getElementById("submit-label") as HTMLElement;
    btn.disabled = true;
    spinner.classList.remove("hidden");
    label.textContent = d.labelSubmitting!;

    const result = await submitContactForm({
      name: sanitize(nome),
      email: sanitize(email),
      phone: sanitize(telefone),
      message: sanitize(mensagem),
    });

    btn.disabled = false;
    spinner.classList.add("hidden");
    label.textContent = d.labelSubmit!;
    feedback.classList.remove("hidden");

    if (result.success) {
      feedback.textContent = d.msgSuccess!;
      feedback.className = "text-sm text-green-600";
      form.reset();
    } else {
      feedback.textContent = result.error ?? d.msgError!;
      feedback.className = "text-sm text-red-500";
    }
  });
</script>
