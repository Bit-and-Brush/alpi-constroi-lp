---
import { testimonials } from "@/data/testimonials";
---

<section class="w-full bg-white py-16 md:py-24" id="avaliacoes">
  <div class="container mx-auto px-6">
    <!-- Header -->
    <div class="flex flex-col gap-6 mb-12">
      <span
        class="bg-foreground text-white text-sm px-4 py-1 rounded-full w-fit scroll-fade-up"
      >
        Avaliações
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-foreground scroll-fade-up">
        O Que Dizem Os Nossos Clientes
      </h2>
    </div>

    <!-- Card grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        testimonials.map((testimonial) => (
          <div class="border border-gray-200 rounded-2xl p-6 flex flex-col gap-4 scroll-fade-up">
            <!-- Avatar + name -->
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 rounded-full bg-gray-200 shrink-0" />
              <div>
                <p class="font-semibold text-foreground">{testimonial.name}</p>
                <p class="text-sm text-foreground/60">{testimonial.role}</p>
              </div>
            </div>
            <!-- Separator -->
            <hr class="border-gray-100" />
            <!-- Quote -->
            <p class="text-foreground/80 leading-relaxed text-sm md:text-base">
              {testimonial.quote}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
