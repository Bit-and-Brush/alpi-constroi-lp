---
import { Image } from "astro:assets";
import Logo from "@/assets/img/alpi-constroi-logo.webp";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const lang = (Astro.currentLocale ?? "pt") as Lang;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const linkClass =
  "text-sm text-foreground/70 underline underline-offset-2 hover:text-foreground transition-colors";
---

<footer class="bg-white border-t border-gray-200">
  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Col 1: Logo + tagline -->
      <div class="flex flex-col gap-4">
        <Image
          src={Logo}
          alt="Alpiconstrói"
          class="h-16 w-auto object-contain object-left"
        />
        <p class="text-sm text-foreground/70 leading-relaxed">
          {t("footer.tagline")}
        </p>
      </div>

      <!-- Col 2: Empresa -->
      <div class="flex flex-col gap-4">
        <p class="font-semibold text-foreground">{t("footer.company")}</p>
        <ul class="flex flex-col gap-3">
          <li><a href="#sobre" class={linkClass}>{t("footer.about")}</a></li>
          <li><a href="#servicos" class={linkClass}>{t("footer.services")}</a></li>
          <li><a href="#projetos" class={linkClass}>{t("footer.projects")}</a></li>
          <li><a href="#diferenciais" class={linkClass}>{t("footer.differentiators")}</a></li>
        </ul>
      </div>

      <!-- Col 3: Utilitários -->
      <div class="flex flex-col gap-4">
        <p class="font-semibold text-foreground">{t("footer.utilities")}</p>
        <ul class="flex flex-col gap-3">
          <li><a href="#contacto" class={linkClass}>{t("footer.contact")}</a></li>
          <li><a href="#faq" class={linkClass}>{t("footer.faq")}</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-200">
    <div class="container mx-auto px-6 py-6">
      <p class="text-sm text-foreground/60">
        &copy; {year} Alpiconstrói Constrói, Lda. {t("footer.copyright")}
        {t("footer.madeBy")} <a
          href="#"
          class="underline underline-offset-2 hover:text-foreground transition-colors"
          >Bit & Brush</a
        >.
      </p>
    </div>
  </div>
</footer>
