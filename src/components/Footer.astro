---
import Logo from "@/assets/img/alpi-constroi-logo.webp";
import { Image } from "astro:assets";

const linkClass =
  "text-sm text-foreground/70 underline underline-offset-2 hover:text-foreground transition-colors";
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200">
  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Col 1: Logo + tagline -->
      <div class="flex flex-col gap-4">
        <Image
          src={Logo}
          alt="Alpiconstrói"
          class="h-16 w-auto object-contain object-left"
        />
        <p class="text-sm text-foreground/70 leading-relaxed">
          A sua parceira de confiança em Construção Civil e Obras Públicas em
          Angola, desde 2007. Construindo o Futuro, Hoje!
        </p>
      </div>

      <!-- Col 2: Empresa -->
      <div class="flex flex-col gap-4">
        <p class="font-semibold text-foreground">Empresa</p>
        <ul class="flex flex-col gap-3">
          <li><a href="#sobre" class={linkClass}>Sobre nós</a></li>
          <li><a href="#servicos" class={linkClass}>Serviços</a></li>
          <li><a href="#projetos" class={linkClass}>Realizações</a></li>
          <li><a href="#diferenciais" class={linkClass}>Diferenciais</a></li>
        </ul>
      </div>

      <!-- Col 3: Utilitários -->
      <div class="flex flex-col gap-4">
        <p class="font-semibold text-foreground">Utilitários</p>
        <ul class="flex flex-col gap-3">
          <li><a href="#contacto" class={linkClass}>Contactos</a></li>
          <li><a href="#faq" class={linkClass}>FAQ</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-200">
    <div class="container mx-auto px-6 py-6">
      <p class="text-sm text-foreground/60">
        &copy; {year} Alpiconstrói Constrói, Lda. Todos os direitos reservados.
        Feito Pela <a
          href="#"
          class="underline underline-offset-2 hover:text-foreground transition-colors"
          >Bit & Brush</a
        >.
      </p>
    </div>
  </div>
</footer>
