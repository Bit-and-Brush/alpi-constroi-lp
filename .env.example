# Resend — envio de email do formulário de contato (/api/contact)

# Chave de API do Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Caixa que recebe os contatos do site
CONTACT_TO=geral@teste.com

# Remetente — apenas o ENDEREÇO de um domínio VERIFICADO no Resend.
# O nome exibido é montado em runtime a partir do nome digitado no form,
# ex.: "João da Silva (via site) <site@alpiconstroi.com>".
# Para testar sem domínio verificado, use: onboarding@resend.dev
# (nesse caso o CONTACT_TO precisa ser o email da sua conta Resend)
CONTACT_FROM=site@teste.com
